<Window x:Class="WKProjectSolver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WK Project Solver" Height="450" Width="800">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Folder Selection -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="FolderPathBox"
                     Margin="0,0,10,0"
                     Height="30"
                     VerticalContentAlignment="Center"/>

            <Button Grid.Column="1"
                    Content="Browse"
                    Width="80"
                    Height="30"
                    Click="Browse_Click"/>
        </Grid>
        

        <TextBox x:Name="LogConsole"
                 Grid.Row="1"
                 Margin="0,10,0,10"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 FontFamily="Consolas"
                 FontSize="13"/>


        <!-- Objectives Checklist -->
        <ScrollViewer Grid.Row="2" Margin="0,10,0,10" VerticalScrollBarVisibility="Hidden">
            <StackPanel x:Name="ObjectiveList">

                <CheckBox x:Name="RemovedBurstMathematics"
                          Content="Removed Burst and Mathematics Files"
                          FontSize="14"
                          Margin="0,5"
                          IsHitTestVisible="False"/>

                <CheckBox x:Name="ReplacedShaders"
                          Content="Replaced Missing Shaders"
                          FontSize="14"
                          Margin="0,5"
                          IsHitTestVisible="False"/>

                <CheckBox x:Name="CopiedInputFiles"
                          Content="Copied Input Files"
                          FontSize="14"
                          Margin="0,5"
                          IsHitTestVisible="False"/>
                
                <CheckBox x:Name="AddedScript"
                          Content="Added Editor Script to Unity"
                          FontSize="14"
                          Margin="0,5"
                          IsHitTestVisible="False"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Resolve Button -->
        <Button Grid.Row="2"
                Content="Resolve"
                Width="150"
                Height="45"
                HorizontalAlignment="Right"
                Margin="0,10"
                FontSize="16"
                Click="Resolve_Click"/>
        
    </Grid>
</Window>
